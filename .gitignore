# Python / bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyc
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
.venv*
venv*

# Environment / secret files (VERY IMPORTANT for your APIs)
.env
.env.local
.env.development
.env.test
.env.production
*.env.*
secrets.yaml
config.yaml          # ← only if it contains secrets; comment out if yours is safe

# Dependency management
pip-log.txt
pip-delete-this-directory.txt
Pipfile.lock         # ← usually safe to commit, but many people ignore it
poetry.lock          # ← same as above – decide based on your workflow

# Distribution / packaging
*.egg-info/
dist/
build/
eggs/
.eggs/
*.egg
*.eggs/
parts/
sdist/
var/
wheels/
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.coverage*
.tox/
.nox/
.cache/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo
*.swn
*.sublime-*
*.code-workspace

# OS / file system junk
.DS_Store
Thumbs.db
ehthumbs.db
*.tmp
*.bak
*.log
*.logs/
*.trace

# RAG / vector DB / data folders (very common in RAG projects)
data/                # ← raw documents, PDFs, etc.
vectorstore/         # ← Chroma, FAISS, etc. persistent storage
chroma_db/
faiss_index/
indexes/
embeddings/
cache/
*.chroma
*.faiss
*.annoy
*.hnsw

# Large files / checkpoints (very frequent in RAG/LLM work)
*.bin
*.pt
*.pth
*.safetensors
*.gguf
*.ggml
*.model
checkpoints/
models/              # ← only ignore if you download huge models locally

# Jupyter / notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints/
*.ipynb

# Logs & temp files generated by many LLM/RAG libs
*.log
wandb/
tensorboard/
runs/
lightning_logs/
mlruns/

# Optional: if you're using Docker locally
docker-compose.override.yml